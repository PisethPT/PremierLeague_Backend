@using PremierLeague_Backend.Models.ViewModels
@model NewsViewModel
@{
    ViewData["Title"] = "News";
    int index = 0;
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="bg-red-100 border-red-700 text-red-700 px-4 py-2 rounded-t-lg mb-4 flex justify-between transition-all duration-300"
         id="errorAlertPanel">
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
        <div class="flex items-center justify-center w-8 h-8 rounded-full cursor-pointer">
            <button onclick="closeAlertPanel('errorAlertPanel')" class="text-red-700">✕</button>
        </div>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-[#8a3fbf] text-white px-4 py-2 rounded-t-lg mb-4 flex justify-between items-center transition-all duration-300 hover:ring-2 hover:!ring-[#8a3fbf]"
         id="infoAlertPanel">
        <span>@TempData["SuccessMessage"]</span>
        <div class="flex items-center justify-center w-8 h-8 rounded-full cursor-pointer">
            <button onclick="closeAlertPanel('infoAlertPanel')" class="text-white">✕</button>
        </div>
    </div>
}

<div id="modalBackdrop" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-40"></div>

<div id="modal" class="hidden fixed inset-0 z-50 flex items-center justify-center m-4">
    <div id="modalBox"
         class="bg-[#1e0021] rounded-2xl shadow-xl transition-all duration-300 scale-90 opacity-0 w-full max-w-5xl max-h-[90vh] flex flex-col"
         onclick="event.stopPropagation()">

        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-white" id="modalTitle">Create News</h2>
            <button onclick="closeModal()"
                    class="bg-[#55005a] text-white flex items-center justify-center w-8 h-8 rounded-full hover:bg-[#410544] cursor-pointer hover:ring-2 hover:!ring-[#8a3fbf]">
                <i class="fa-solid fa-xmark text-white"></i>
            </button>
        </div>

        <form id="newsForm" asp-controller="News" asp-action="Create" method="post" asp-antiforgery="true"
              class="h-auto p-2" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" id="newsId" asp-for="NewsDto.NewsId" />
            <input type="hidden" id="imageUrl" asp-for="NewsDto.ImageUrl" />
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-4">
                <label class="flex flex-col gap-2">
                    <span class="flex items-center justify-between">
                        <span class="text-white font-medium">Title <span class="text-red-400">*</span></span>
                        <span class="text-xs text-gray-400">
                            <span data-count-for="title">0</span> / 200
                        </span>
                    </span>
                    <textarea id="title" asp-for="NewsDto.Title" type="text"
                              class="char-counter-input overflow-y-auto scrollbar-none bg-[#55005a] text-white placeholder:text-gray-500 placeholder:italic rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#8a3fbf]"
                              placeholder="title allow less then 200 characters" rows="4" maxlength="200"></textarea>
                    <span asp-validation-for="NewsDto.Title" class="text-red-400 text-sm"></span>
                </label>

                <label class="flex flex-col gap-2">
                    <span class="flex items-center justify-between">
                        <span class="text-white font-medium">Subtitle </span>
                        <span class="text-xs text-gray-400">
                            <span data-count-for="subtitle">0</span> / 500
                        </span>
                    </span>

                    <textarea id="subtitle" asp-for="NewsDto.Subtitle" type="text"
                              class="char-counter-input overflow-y-auto scrollbar-none bg-[#55005a] text-white placeholder:text-gray-500 placeholder:italic rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#8a3fbf]"
                              placeholder="subtitle allow less then 500 characters" rows="4" maxlength="500"></textarea>
                </label>
            </div>

            <label class="flex flex-col gap-2">
                <span class="flex items-center justify-between">
                    <span class="text-white font-medium">Content <span class="text-red-400">*</span></span>
                    <span class="text-xs text-gray-400">
                        <span data-count-for="content">0</span> / 4000
                    </span>
                </span>

                <textarea id="content" asp-for="NewsDto.Content" placeholder="content allow less then 4000 characters"
                          maxlength="4000"
                          class="char-counter-input overflow-y-auto scrollbar-none bg-[#55005a] text-white placeholder:text-gray-500 placeholder:italic rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#8a3fbf]"
                          rows="4"></textarea>
                <span asp-validation-for="NewsDto.Content" class="text-red-400 text-sm"></span>
            </label>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-4">
                <label class="flex flex-col gap-2">
                    <span class="text-white font-medium">Reference URL</span>
                    <input id="referenceUrl" type="url" asp-for="NewsDto.ReferenceUrl"
                           placeholder="https://youtube.com/..."
                           class="bg-[#55005a] text-white rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#8a3fbf] outline-none" />
                </label>
                <label class="flex flex-col gap-2">
                    <span class="text-white font-medium">Video Reference URL</span>
                    <input id="videoReferenceUrl" type="url" asp-for="NewsDto.VideoReferenceUrl"
                           placeholder="https://youtube.com/..."
                           class="bg-[#55005a] text-white rounded-lg px-4 py-2 focus:ring-2 focus:ring-[#8a3fbf] outline-none" />
                </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-3 gap-4 mt-2">
                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">News Tag <span class="text-red-400">*</span></span>
                    </span>
                    <select id="selectNewsTag" class="js-custom-select" asp-for="NewsDto.NewsTagId"
                            data-placeholder="Select news tag">
                        <option value="">Select News Tag</option>
                        @foreach (var tag in Model.SelectListItemNewsTag)
                        {
                            <option value="@tag.Value" data-sub="@tag.Subtitle">@tag.Label</option>
                        }
                    </select>
                    <span asp-validation-for="NewsDto.NewsTagId" class="text-red-400 text-sm"></span>
                </label>

                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">News Category <span class="text-red-400">*</span></span>
                    </span>
                    <select id="selectNewsCategory" class="js-custom-select" asp-for="NewsDto.NewsCategoryId"
                            data-placeholder="Select news category">
                        <option value="">Select News Category</option>
                        @foreach (var category in Model.SelectListItemNewsCategories)
                        {
                            <option value="@category.Value">@category.Text</option>
                        }
                    </select>
                    <span asp-validation-for="NewsDto.NewsCategoryId" class="text-red-400 text-sm"></span>
                </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-3 gap-4 mt-2">
                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">Club</span>
                    </span>
                    <select id="selectClub" class="js-custom-select" asp-for="NewsDto.ClubId"
                            data-placeholder="Select club" data-show-image="true">
                        <option value="">Select Club</option>
                        @foreach (var club in Model.SelectListItemClubs)
                        {
                            <option value="@club.ClubId" data-img="/upload/clubs/@club.ClubCrest"
                                    data-sub="@club.ClubTheme">
                                @club.ClubName
                            </option>
                        }
                    </select>
                </label>

                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">Match</span>
                    </span>
                    <select id="selectMatch" class="js-custom-select" asp-for="NewsDto.MatchId"
                            data-placeholder="Select Match">
                        @foreach (var lineup in Model.SelectListItemMatches)
                        {
                            <option value="@lineup.MatchId" data-sub="@lineup.MatchSubContent"
                                    data-home-img="/upload/clubs/@lineup.HomeClubCrest"
                                    data-away-img="/upload/clubs/@lineup.AwayClubCrest" data-home-theme="@lineup.HomeTheme"
                                    data-away-theme="@lineup.AwayTheme">
                                @lineup.MatchContent
                            </option>
                        }
                    </select>
                </label>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 gap-4 mt-2">
                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">Published Date <span class="text-red-400">*</span></span>
                    </span>

                    <input id="publishedDate" asp-for="NewsDto.PublishedDate" type="date"
                           class="bg-[#55005a] text-white placeholder:text-gray-400 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#8a3fbf]" />
                    <span asp-validation-for="NewsDto.PublishedDate" class="text-red-400 text-sm"></span>
                </label>

                <label class="flex flex-col gap-2">
                    <span class="flex items-center gap-1">
                        <span class="text-white font-medium">Expiry Date <span class="text-red-400">*</span></span>
                    </span>

                    <input id="expiryDate" asp-for="NewsDto.ExpiryDate" type="date"
                           class="bg-[#55005a] text-white placeholder:text-gray-400 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#8a3fbf]" />
                    <span asp-validation-for="NewsDto.ExpiryDate" class="text-red-400 text-sm"></span>
                </label>
            </div>

            <div class="flex flex-col gap-2 my-3">
                <div class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-3 gap-4 bg-white/5 p-4 rounded-lg">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input id="isFeaturedHidden" type="hidden" name="NewsDto.IsFeatured" value="false" />
                        <input id="isFeatured" type="checkbox" asp-for="NewsDto.IsFeatured"
                               class="w-5 h-5 accent-[#8a3fbf]">
                        <span class="text-white group-hover:text-[#8a3fbf] transition">This news is featured</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input id="isVideoHidden" type="hidden" name="NewsDto.IsVideo" value="false" />
                        <input id="isVideo" type="checkbox" asp-for="NewsDto.IsVideo" class="w-5 h-5 accent-[#8a3fbf]">
                        <span class="text-white group-hover:text-[#8a3fbf] transition">This is a video news</span>
                    </label>

                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input id="isQuizzesHidden" type="hidden" name="NewsDto.IsQuizzes" value="false" />
                        <input id="isQuizzes" type="checkbox" asp-for="NewsDto.IsQuizzes"
                               class="w-5 h-5 accent-[#8a3fbf]">
                        <span class="text-white group-hover:text-[#8a3fbf] transition">This is a Games, Quizzes & Polls
                            news</span>
                        </label>

                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input id="isRelatedContentHidden" type="hidden" name="NewsDto.IsRelatedContent"
                                   value="false" />
                            <input id="isRelatedContent" type="checkbox" asp-for="NewsDto.IsRelatedContent"
                                   class="w-5 h-5 accent-[#8a3fbf]">
                            <span class="text-white group-hover:text-[#8a3fbf] transition">This is new as Related
                                Content</span>
                            </label>

                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input id="isPremierLeagueGameHidden" type="hidden" name="NewsDto.IsPremierLeagueGame"
                                       value="false" />
                                <input id="isPremierLeagueGame" type="checkbox" asp-for="NewsDto.IsPremierLeagueGame"
                                       class="w-5 h-5 accent-[#8a3fbf]">
                                <span class="text-white group-hover:text-[#8a3fbf] transition">This is a Premier League Game
                                    news</span>
                                </label>

                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input id="isActiveHidden" type="hidden" name="NewsDto.IsActive" value="true" />
                                    <input id="isActive" type="checkbox" checked asp-for="NewsDto.IsActive"
                                           class="w-5 h-5 accent-[#8a3fbf]">
                                    <span class="text-white group-hover:text-[#8a3fbf] transition">Active / Visible</span>
                                </label>
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <span class="flex items-center gap-1">
                                <span class="text-white font-medium">News Photo</span>
                                <span class="text-red-400">*</span>
                            </span>

                            <div id="dropZone"
                                 class="relative flex flex-col items-center justify-center min-h-[220px] border-2 border-dashed border-white/20 rounded-lg overflow-hidden transition hover:border-white/40">

                                <input id="fileInput" asp-for="NewsDto.ImageFile" type="file" accept="image/*"
                                       class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                                       aria-label="Upload user photo" />

                                <div id="uploadPrompt" class="flex flex-col items-center justify-center gap-3 p-4">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white/80" fill="none"
                                         viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                              d="M7 16V7a1 1 0 011-1h3m6 11v-5a1 1 0 00-1-1h-3M7 16l3-3 2 2 4-4 3 3" />
                                    </svg>
                                    <div class="text-center">
                                        <div class="text-gray-400 font-medium">Drag & drop file or click to browse</div>
                                        <div class="text-xs text-gray-500">PNG, JPG, SVG, WEBP — max 2 MB</div>
                                    </div>
                                </div>

                                <div id="previewArea" class="hidden absolute inset-0 w-auto h-auto z-20 bg-white/5">
                                    <img id="filePreview" src="" alt="file preview" class="w-auto h-auto object-contain">

                                    <button type="button" id="removePhoto"
                                            class="absolute top-3 right-3 px-3 py-1.5 bg-[#55005a] text-white text-xs font-bold rounded shadow-xl hover:bg-[#3a0531] transition-colors border border-white/10">
                                        Remove
                                    </button>

                                    <div class="absolute bottom-0 left-0 right-0 bg-white/5 backdrop-blur-sm p-2">
                                        <p id="fileName" class="text-white text-xs truncate text-center font-mono"></p>
                                        <p id="fileSize" class="text-[10px] text-gray-300 text-center"></p>
                                    </div>
                                </div>
                            </div>

                            <p id="fileError" class="text-xs text-rose-300 hidden">File is too large or invalid format.</p>
                            <span asp-validation-for="NewsDto.ImageFile" class="text-xs text-red-400"></span>
                        </div>

                        <div class="mt-6 flex flex-col md:flex-row justify-between gap-3">
                            <div class="text-sm text-gray-200/80">Fields with <span class="text-red-400">*</span> are required.
                            </div>
                            <div class="flex gap-3">
                                <button type="reset" id="resetBtn"
                                        class="text-white px-4 py-2 bg-[#410544] rounded-lg hover:bg-[#55005a] transition hover:ring-2 hover:!ring-[#8a3fbf]">Reset</button>
                                <button type="submit"
                                        class="text-white px-4 py-2 bg-[#8a3fbf] rounded-lg hover:bg-[#6b2fa0] transition hover:ring-2 hover:!ring-[#8a3fbf]">Submit</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div id="confirmDeleteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center m-4">
                <div class="modalBox !bg-[#1e0021] rounded-2xl shadow-xl p-6 transition-all duration-300 scale-90 opacity-0"
                     onclick="event.stopPropagation()">

                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-xl font-semibold text-white">Delete News</h2>
                    </div>

                    <div class="p-4 rounded-lg bg-[#55005a]/60 border border-[#8a3fbf]/40">
                        <div class="flex items-start gap-3">
                            <div class="text-red-300 text-xl">⚠️</div>
                            <div>
                                <p class="text-white text-base font-medium">
                                    Are you sure you want to delete this news?
                                </p>
                                <p class="text-red-300 text-sm mt-1">
                                    This action is permanent and cannot be undone.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col items-center gap-4 mt-4 rounded-2xl px-4 w-full overflow-hidden">
                        <div class="flex h-full float-end">
                            <img id="imageUrlDisplay" src="" class="w-auto h-50 mt-4 object-contain cursor-pointer mb-0"
                                 alt="news" />
                        </div>
                        <div class="flex flex-col justify-start mb-3 gap-1 h-full w-auto">
                            <div id="titleDisplay" class="text-left text-sm text-white align-middle font-medium w-fit truncate">
                            </div>
                            <div id="contentDisplay" class="text-left text-xs text-white align-middle font-normal w-96 truncate">
                            </div>
                        </div>
                    </div>

                    <form id="confirmDeleteForm" asp-controller="News" asp-action="Delete" method="post" asp-antiforgery="true"
                          class="h-auto p-2 mt-6" enctype="multipart/form-data" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="newsId" asp-for="NewsDto.NewsId" />
                        <div class="flex flex-col md:flex-row justify-end gap-3">
                            <button type="button" onclick="hideModal('confirmDeleteModal')"
                                    class="text-white px-4 py-2 bg-[#410544] rounded-lg hover:bg-[#55005a] transition hover:ring-2 hover:!ring-[#8a3fbf]">
                                Cancel
                            </button>

                            <button type="submit"
                                    class="text-white px-4 py-2 bg-red-500 rounded-lg hover:bg-red-600 transition hover:ring-2 hover:!ring-[#8a3fbf]">
                                Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="p-4 bg-[#37003c] rounded-lg shadow-lg space-y-4 overflow-hidden">
                <div class="flex flex-col lg:flex-row justify-between lg:items-center gap-4 w-full">
                    <div class="flex items-center justify-between lg:justify-start gap-4">
                        <a href="@Url.Action("Index", "News")"
                           class="inline-block bg-[#55005a] text-white px-4 py-2 hover:bg-[#410544] rounded-lg transition hover:ring-2 hover:!ring-[#8a3fbf] text-nowrap">Back
                            to
                            Home</a>

                            <button onclick="openModal('modal-8xl', true)"
                                    class="inline-block bg-[#8a3fbf] hover:bg-[#6b2fa0] text-white px-4 py-2 rounded-lg transition hover:ring-2 hover:!ring-[#8a3fbf] text-nowrap"
                                    id="btnAddNews">Add New</button>
                        </div>
                    </div>

                    <div class="overflow-x-scroll overflow-y-auto max-h-[78vh] scrollbar-none overflow-hidden rounded-t-lg">
                        <table class="min-w-full divide-y divide-[#55005a]">
                            <thead class="bg-[#55005a] sticky top-0 z-10">
                                <tr>
                                    <th class="px-2 py-3 text-xs font-medium text-white uppercase tracking-wider text-center">ID</th>
                                    <th class="px-2 py-3 text-xs font-medium text-white uppercase tracking-wider text-center">Action
                                    </th>
                                    <th
                                        class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider whitespace-nowrap">
                                        Status
                                    </th>
                                    <th class="px-0 py-2 text-center text-xs font-medium text-white uppercase tracking-wider w-fit">
                                        News Image
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                                        Title
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Subtitle
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Content
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Tag Name
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Author
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Published Date
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider text-nowrap">
                                        Expiry Date
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="bg-transparent divide-y divide-[#55005a]">
                                @foreach (var news in Model.NewsDetailDtos)
                                {
                                    index++;
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="px-2 py-3 whitespace-nowrap text-sm text-white text-center align-middle">
                                            <div
                                                class="w-8 h-8 mx-auto text-white text-sm font-bold flex justify-center items-center bg-[#55005a] rounded-full ring-2 ring-[#8a3fbf]">
                                                @index
                                            </div>
                                        </td>
                                        <td class="px-2 py-3 whitespace-nowrap text-sm text-white align-middle">
                                            <div class="flex justify-center items-center gap-2">
                                                <button onclick="toggleEditNews(@news.NewsId)"
                                                        class="w-9 h-9 text-white bg-[#8a3fbf] hover:bg-[#6b2fa0] rounded-xl flex justify-center items-center transition-all">
                                                    <i class="fa-solid fa-pencil"></i>
                                                </button>
                                                <button onclick="showModal('confirmDeleteModal', this, 'modal-lg', true)"
                                                        class="w-9 h-9 text-white bg-red-500 hover:bg-red-600 rounded-xl flex justify-center items-center transition-all">
                                                    <input type="hidden" name="newsId" value="@news.NewsId" />
                                                    <input type="hidden" name="title" value="@news.Title" />
                                                    <input type="hidden" name="content" value="@news.Content" />
                                                    <input type="hidden" name="image" value="@news.ImageUrl" />
                                                    <i class="fa-solid fa-circle-minus"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap text-left text-sm text-white align-middle">
                                            <span class="px-2 py-1 rounded-md text-xs @(news.IsActive ? "bg-green-600" : "bg-gray-600")">
                                                @(news.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                        <td class="px-0 py-2 w-auto h-24 min-w-[96px] align-middle overflow-hidden">
                                            <img src="~/upload/news/@news.ImageUrl" alt="@news.Title"
                                                 class="w-auto h-24 block object-cover transition-all duration-300 @(news.IsActive ? "grayscale-0" : "grayscale opacity-60")" />
                                        </td>
                                        <td class="px-4 py-3 text-left text-sm text-white align-middle font-medium">
                                            <div class="w-48 truncate" title="@news.Title">@news.Title</div>
                                        </td>
                                        <td class="px-4 py-3 text-left text-sm text-gray-300 align-middle">
                                            <div class="w-40 truncate" title="@news.Subtitle">@news.Subtitle</div>
                                        </td>
                                        <td class="px-4 py-3 text-left text-sm text-white align-middle font-medium">
                                            <div class="w-48 truncate" title="@news.Content">@news.Content</div>
                                        </td>
                                        <td class="px-6 py-3 whitespace-nowrap text-left text-sm text-white align-middle">@news.NewsTagName
                                        </td>
                                        <td class="px-6 py-3 whitespace-nowrap text-left text-sm text-white align-middle">@news.Author</td>
                                        <td class="px-6 py-3 whitespace-nowrap text-left text-sm text-white align-middle">
                                            @news.PublishedDate</td>
                                            <td class="px-6 py-3 whitespace-nowrap text-left text-sm text-white align-middle">@news.ExpiryDate
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="@(ViewBag.TotalCount > 11 ? "flex" : "hidden") items-center mt-4 border-t-2 border-[#55005a] pt-4">
                            <div class="text-sm text-gray-400">
                                Total News: @ViewBag.TotalCount
                                Page @ViewBag.CurrentPage of @ViewBag.TotalPages
                            </div>

                            <div class="ml-auto flex items-center gap-4">
                                <a href="@Url.Action("Index", "News", new { page = ViewBag.CurrentPage - 1 })"
                                   class="px-3 py-1 rounded bg-[#55005a] text-white transition
                                    @(ViewBag.CurrentPage == 1 ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-[#410544] hover:ring-2 hover:!ring-[#8a3fbf]")"
                                   aria-disabled="@(ViewBag.CurrentPage == 1)">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </a>
                                <a href="@Url.Action("Index", "News", new { page = ViewBag.CurrentPage + 1 })"
                                   class="px-3 py-1 rounded bg-[#55005a] text-white transition
                                    @(ViewBag.CurrentPage == ViewBag.TotalPages ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-[#410544] hover:ring-2 hover:!ring-[#8a3fbf]")"
                                   aria-disabled="@(ViewBag.CurrentPage == ViewBag.TotalPages)">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    @section Scripts {
                        <partial name="_ValidationScriptsPartial" />
                        <script src="/js/news/index.js" asp-append-version="true"></script>
                        <script src="/js/news/delete.js" asp-append-version="true"></script>
                    }
